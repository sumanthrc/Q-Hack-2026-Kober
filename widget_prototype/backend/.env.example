# .env.example — Copy to .env and fill in your values
# cp .env.example .env

# ── Database (Neon PostgreSQL) ──
# Use either DATABASE_URL (full connection string) or individual fields
DATABASE_URL=postgresql://user:password@host:5432/dbname?sslmode=require

# Or use individual fields (DB_HOST is used as DSN fallback)
# DB_HOST=postgresql://user:password@host:5432/dbname?sslmode=require
# DB_PORT=5432
# DB_NAME=your_db_name
# DB_USER=your_db_user
# DB_PASSWORD=your_db_password

# ── Gemini API (optional, for LLM-enriched recommendations) ──
GEMINI_API_KEY=your_gemini_api_key_here
